generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// INI KHUSUS UNTUK TOMBOL "LOGIN WITH GOOGLE"
// ============================================
model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Tabel User Utama
model User {
  id        String   @id @default(uuid())
  name      String?
  email     String?   @unique
  emailVerified DateTime?
  image     String?

  username  String?   @unique
  password  String?

  accounts  Account[]
  sessions  Session[]

  // Relasi: Satu user bisa punya banyak riwayat Vibe
  vibes     VibeStatus[]
}

// Tabel Riwayat Status Vibe
model VibeStatus {
  id             String   @id @default(uuid())
  batteryLevel   Int      // Persentase baterai sosial (0 - 100)
  moodText       String   // "Lagi pengen nongkrong", "Lagi gabut", dsb
  currentActivity String?  // "Nonton Netflix", "Coding", "Denger lagu galau"
  musicUrl       String?  // Link Spotify atau Apple Music
  createdAt      DateTime @default(now())

  // Relasi ke User
  userId         String
  user           User     @relation(fields: [userId], references: [id])
}
